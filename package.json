{
  "name": "gradient-factor-visualizer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Gradient Factor Visualizer — teaching/visualization tool for how GF settings change a decompression profile. Milestone 1: engine only.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --noEmit",
    "report": "vitest run engine/__tests__/reference-profiles.test.ts --reporter=verbose"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
